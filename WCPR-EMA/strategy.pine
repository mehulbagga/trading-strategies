//@version=5
strategy("Weekly CPR + EMA Trend Strategy [FX]", shorttitle="WCPR+EMA", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=2, commission_type=strategy.commission.percent, commission_value=0.03, slippage=2, max_bars_back=500)

// ─────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────
grp1 = "═══ EMA Settings ═══"
ema_fast   = input.int(21,  "Fast EMA",  minval=1, group=grp1)
ema_slow   = input.int(50,  "Slow EMA",  minval=1, group=grp1)
ema_trend  = input.int(200, "Trend EMA (200)", minval=1, group=grp1)
show_emas  = input.bool(true, "Show EMAs", group=grp1)

grp2 = "═══ Weekly CPR Settings ═══"
show_cpr       = input.bool(true, "Show Weekly CPR Levels", group=grp2)
cpr_width      = input.int(2, "CPR Line Width", minval=1, maxval=4, group=grp2)

grp3 = "═══ Entry & Filter Settings ═══"
use_ema_filter    = input.bool(true,  "Use EMA Trend Filter (200 EMA)", group=grp3)
use_cpr_filter    = input.bool(true,  "Only trade when price is outside CPR", group=grp3)
use_ema_cross     = input.bool(true,  "Use 21/50 EMA Crossover", group=grp3)
min_cpr_dist_pips = input.float(5.0,  "Min Distance from CPR (pips)", minval=0, group=grp3)
atr_period        = input.int(14, "ATR Period", minval=1, group=grp3)

grp4 = "═══ Risk Management ═══"
sl_atr_mult    = input.float(1.5, "Stop Loss ATR Multiplier",     minval=0.5, step=0.1, group=grp4)
tp_atr_mult    = input.float(3.0, "Take Profit ATR Multiplier",   minval=0.5, step=0.1, group=grp4)
use_pivot_sl   = input.bool(false, "Use CPR as Stop Loss Base",   group=grp4)
trail_stop     = input.bool(true,  "Use Trailing Stop",           group=grp4)
trail_atr_mult = input.float(2.0, "Trailing Stop ATR Multiplier", minval=0.5, step=0.1, group=grp4)

grp5 = "═══ Session Filter ═══"
use_session  = input.bool(false, "Filter by Trading Session", group=grp5)
london_open  = input.bool(true,  "London Session (07:00-16:00 GMT)", group=grp5)
newyork_open = input.bool(true,  "New York Session (12:00-21:00 GMT)", group=grp5)

grp6 = "═══ Visual Settings ═══"
bull_color = input.color(color.new(#00E5FF, 0),  "Bullish Color",  group=grp6)
bear_color = input.color(color.new(#FF1744, 0),  "Bearish Color",  group=grp6)
cpr_color  = input.color(color.new(#FFD600, 80), "CPR Band Color", group=grp6)
tc_color   = input.color(color.new(#FFD600, 0),  "TC Line Color",  group=grp6)
bc_color   = input.color(color.new(#FF9800, 0),  "BC Line Color",  group=grp6)
pp_color   = input.color(color.new(#FFFFFF, 0),  "Pivot Color",    group=grp6)

// ─────────────────────────────────────────────
// WEEKLY CPR CALCULATIONS
// ─────────────────────────────────────────────
w_high  = request.security(syminfo.tickerid, "W", high[1],  lookahead=barmerge.lookahead_on)
w_low   = request.security(syminfo.tickerid, "W", low[1],   lookahead=barmerge.lookahead_on)
w_close = request.security(syminfo.tickerid, "W", close[1], lookahead=barmerge.lookahead_on)

weekly_pp  = (w_high + w_low + w_close) / 3
weekly_bc  = (w_high + w_low) / 2
weekly_tc  = (weekly_pp - weekly_bc) + weekly_pp

cpr_top    = math.max(weekly_tc, weekly_bc)
cpr_bottom = math.min(weekly_tc, weekly_bc)
cpr_mid    = weekly_pp

cpr_width_val  = math.abs(cpr_top - cpr_bottom)
cpr_width_pips = cpr_width_val / syminfo.mintick / 10
is_narrow_cpr  = cpr_width_pips < 20

// ─────────────────────────────────────────────
// EMA CALCULATIONS
// ─────────────────────────────────────────────
ema21  = ta.ema(close, ema_fast)
ema50  = ta.ema(close, ema_slow)
ema200 = ta.ema(close, ema_trend)

bull_trend     = ema21 > ema50 and ema50 > ema200
bear_trend     = ema21 < ema50 and ema50 < ema200
ema_cross_up   = ta.crossover(ema21, ema50)
ema_cross_down = ta.crossunder(ema21, ema50)

// ─────────────────────────────────────────────
// ATR
// ─────────────────────────────────────────────
atr = ta.atr(atr_period)

// ─────────────────────────────────────────────
// CPR POSITION
// ─────────────────────────────────────────────
price_above_cpr  = close > cpr_top
price_below_cpr  = close < cpr_bottom
price_inside_cpr = close >= cpr_bottom and close <= cpr_top

sufficient_dist_bull = (math.abs(close - cpr_top)    / syminfo.mintick / 10) >= min_cpr_dist_pips
sufficient_dist_bear = (math.abs(close - cpr_bottom) / syminfo.mintick / 10) >= min_cpr_dist_pips

// ─────────────────────────────────────────────
// SESSION FILTER
// ─────────────────────────────────────────────
london_session   = not use_session or (london_open  and hour >= 7  and hour < 16)
newyork_session  = not use_session or (newyork_open and hour >= 12 and hour < 21)
in_valid_session = london_session or newyork_session

// ─────────────────────────────────────────────
// ENTRY CONDITIONS
// ─────────────────────────────────────────────
long_condition  = (not use_ema_cross  or ema_cross_up)   and (not use_cpr_filter or price_above_cpr) and (not use_ema_filter or close > ema200) and sufficient_dist_bull and in_valid_session and barstate.isconfirmed

short_condition = (not use_ema_cross  or ema_cross_down) and (not use_cpr_filter or price_below_cpr) and (not use_ema_filter or close < ema200) and sufficient_dist_bear and in_valid_session and barstate.isconfirmed

// ─────────────────────────────────────────────
// STRATEGY EXECUTION
// ─────────────────────────────────────────────
if long_condition and strategy.position_size == 0
    long_sl = use_pivot_sl ? cpr_bottom - atr * 0.05 : close - atr * sl_atr_mult
    long_tp = close + atr * tp_atr_mult
    strategy.entry("Long", strategy.long, comment="▲ LONG")
    strategy.exit("Long Exit", "Long", stop=long_sl, limit=long_tp, trail_points=trail_stop ? atr * trail_atr_mult / syminfo.mintick : na, trail_offset=trail_stop ? atr * 0.05 / syminfo.mintick : na)

if short_condition and strategy.position_size == 0
    short_sl = use_pivot_sl ? cpr_top + atr * 0.05 : close + atr * sl_atr_mult
    short_tp = close - atr * tp_atr_mult
    strategy.entry("Short", strategy.short, comment="▼ SHORT")
    strategy.exit("Short Exit", "Short", stop=short_sl, limit=short_tp, trail_points=trail_stop ? atr * trail_atr_mult / syminfo.mintick : na, trail_offset=trail_stop ? atr * 0.05 / syminfo.mintick : na)

// ─────────────────────────────────────────────
// PLOTS — EMAs
// ─────────────────────────────────────────────
p21  = plot(show_emas ? ema21  : na, "EMA 21",  color=bull_color,            linewidth=2)
p50  = plot(show_emas ? ema50  : na, "EMA 50",  color=color.new(#FF9800, 0), linewidth=2)
plot(show_emas ? ema200 : na, "EMA 200", color=color.new(#9E9E9E, 40), linewidth=1, style=plot.style_circles)
fill(p21, p50, color=ema21 > ema50 ? color.new(bull_color, 88) : color.new(bear_color, 88))

// ─────────────────────────────────────────────
// PLOTS — Weekly CPR
// ─────────────────────────────────────────────
tc_line = plot(show_cpr ? cpr_top    : na, "Weekly TC", color=tc_color, linewidth=cpr_width, style=plot.style_stepline)
pp_line = plot(show_cpr ? cpr_mid    : na, "Weekly PP", color=pp_color, linewidth=cpr_width, style=plot.style_stepline)
bc_line = plot(show_cpr ? cpr_bottom : na, "Weekly BC", color=bc_color, linewidth=cpr_width, style=plot.style_stepline)
fill(tc_line, bc_line, color=cpr_color)

// ─────────────────────────────────────────────
// LABELS
// ─────────────────────────────────────────────
var label lbl_tc = na
var label lbl_pp = na
var label lbl_bc = na

if barstate.islast and show_cpr
    label.delete(lbl_tc)
    label.delete(lbl_pp)
    label.delete(lbl_bc)
    lbl_tc := label.new(bar_index + 2, cpr_top,    "TC: " + str.tostring(cpr_top,    format.mintick), color=color.new(tc_color, 30), textcolor=color.black, style=label.style_label_left, size=size.small)
    lbl_pp := label.new(bar_index + 2, cpr_mid,    "PP: " + str.tostring(cpr_mid,    format.mintick), color=color.new(pp_color, 30), textcolor=color.black, style=label.style_label_left, size=size.small)
    lbl_bc := label.new(bar_index + 2, cpr_bottom, "BC: " + str.tostring(cpr_bottom, format.mintick), color=color.new(bc_color, 30), textcolor=color.black, style=label.style_label_left, size=size.small)

// ─────────────────────────────────────────────
// SIGNALS
// ─────────────────────────────────────────────
plotshape(long_condition,  title="Long Signal",  style=shape.triangleup,   location=location.belowbar, color=bull_color, size=size.normal, text="BUY")
plotshape(short_condition, title="Short Signal", style=shape.triangledown, location=location.abovebar, color=bear_color, size=size.normal, text="SELL")

bgcolor(bull_trend ? color.new(bull_color, 96) : bear_trend ? color.new(bear_color, 96) : na)

// ─────────────────────────────────────────────
// INFO TABLE
// ─────────────────────────────────────────────
var table info = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 20), border_color=color.new(color.white, 60), border_width=1, frame_color=color.new(color.white, 40), frame_width=1)

if barstate.islast
    trend_txt   = bull_trend ? "▲ BULLISH" : bear_trend ? "▼ BEARISH" : "◆ NEUTRAL"
    trend_col   = bull_trend ? bull_color  : bear_trend ? bear_color  : color.gray
    cpr_pos_txt = price_above_cpr ? "ABOVE CPR" : price_below_cpr ? "BELOW CPR" : "INSIDE CPR"
    cpr_pos_col = price_above_cpr ? bull_color  : price_below_cpr ? bear_color  : color.orange
    table.cell(info, 0, 0, "WCPR+EMA",        text_color=color.white,  text_size=size.small, bgcolor=color.new(color.navy, 20))
    table.cell(info, 1, 0, syminfo.ticker,     text_color=color.yellow, text_size=size.small, bgcolor=color.new(color.navy, 20))
    table.cell(info, 0, 1, "Trend",            text_color=color.gray,   text_size=size.small)
    table.cell(info, 1, 1, trend_txt,          text_color=trend_col,    text_size=size.small)
    table.cell(info, 0, 2, "CPR Position",     text_color=color.gray,   text_size=size.small)
    table.cell(info, 1, 2, cpr_pos_txt,        text_color=cpr_pos_col,  text_size=size.small)
    table.cell(info, 0, 3, "CPR Width(pips)",  text_color=color.gray,   text_size=size.small)
    table.cell(info, 1, 3, str.tostring(cpr_width_pips, "#.##"), text_color=is_narrow_cpr ? bull_color : color.orange, text_size=size.small)
    table.cell(info, 0, 4, "EMA 21",           text_color=color.gray,   text_size=size.small)
    table.cell(info, 1, 4, str.tostring(ema21, format.mintick), text_color=bull_color,    text_size=size.small)
    table.cell(info, 0, 5, "EMA 50",           text_color=color.gray,   text_size=size.small)
    table.cell(info, 1, 5, str.tostring(ema50, format.mintick), text_color=color.orange,  text_size=size.small)
    table.cell(info, 0, 6, "ATR(14)",          text_color=color.gray,   text_size=size.small)
    table.cell(info, 1, 6, str.tostring(atr,   format.mintick), text_color=color.white,   text_size=size.small)
    table.cell(info, 0, 7, "Narrow CPR",       text_color=color.gray,   text_size=size.small)
    table.cell(info, 1, 7, is_narrow_cpr ? "YES ✓" : "NO", text_color=is_narrow_cpr ? bull_color : color.red, text_size=size.small)

// ─────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────
alertcondition(long_condition,  title="Long Signal",       message="{{ticker}} — LONG Signal | {{close}} | {{interval}}")
alertcondition(short_condition, title="Short Signal",      message="{{ticker}} — SHORT Signal | {{close}} | {{interval}}")
alertcondition(ema_cross_up,    title="EMA Cross Up",      message="{{ticker}} — EMA 21 crossed above EMA 50")
alertcondition(ema_cross_down,  title="EMA Cross Down",    message="{{ticker}} — EMA 21 crossed below EMA 50")