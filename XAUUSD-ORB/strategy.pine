//@version=5
strategy("XAUUSD Opening Range Breakout", overlay=true, margin_long=100, margin_short=100)

// ==================== INPUTS ====================
show_or_box = input.bool(true, "Show Opening Range Box", group="Display")
box_color_bull = input.color(color.new(color.green, 85), "OR Box Color (Bullish)", group="Display")
box_color_bear = input.color(color.new(color.red, 85), "OR Box Color (Bearish)", group="Display")

// ==================== VARIABLES ====================
var float or_high = na
var float or_low = na
var bool or_formed = false
var int or_start_bar = na
var int or_end_bar = na
var box or_box = na

// Trade tracking variables
var float entry_price = na
var float stop_loss = na
var float target = na
var float breakout_candle_low = na
var float breakout_candle_high = na
var bool trade_taken_today = false

// ==================== TIME FUNCTIONS ====================
// Opening range: 6:03 PM to 6:18 PM EST (18:03-18:18)
is_opening_range_start() =>
    hour(time, "America/New_York") == 18 and minute(time, "America/New_York") == 3

is_within_opening_range() =>
    t = time(timeframe.period, "1803-1817:23456", "America/New_York")
    not na(t)

is_new_day() =>
    ta.change(dayofweek) != 0

// ==================== OPENING RANGE LOGIC ====================
// Reset variables on new day
if is_new_day()
    or_high := na
    or_low := na
    or_formed := false
    or_start_bar := na
    or_end_bar := na
    trade_taken_today := false
    if not na(or_box)
        box.delete(or_box)
        or_box := na

// Capture opening range (15 minutes from 6:03 PM to 6:18 PM EST)
if is_within_opening_range()
    if na(or_high) or na(or_low)
        or_high := high
        or_low := low
        or_start_bar := bar_index
    else
        or_high := math.max(or_high, high)
        or_low := math.min(or_low, low)
    or_end_bar := bar_index

// Mark opening range as formed after 6:18 PM EST (18:18)
if not or_formed and not na(or_high) and not na(or_low) and not is_within_opening_range()
    if hour(time, "America/New_York") >= 18 and minute(time, "America/New_York") >= 18
        or_formed := true
        
        // Draw opening range box
        if show_or_box and not na(or_start_bar) and not na(or_end_bar)
            box_right = bar_index + 50
            or_box := box.new(or_start_bar, or_high, box_right, or_low, 
                             border_color=color.new(color.blue, 50), 
                             bgcolor=box_color_bull, 
                             border_width=2,
                             extend=extend.right)

// ==================== ENTRY CONDITIONS ====================
// Buy condition: 3-min candle closes above OR high (only if no trade taken today)
buy_signal = or_formed and not na(or_high) and close > or_high and close[1] <= or_high and not trade_taken_today

// Sell condition: 3-min candle closes below OR low (only if no trade taken today)
sell_signal = or_formed and not na(or_low) and close < or_low and close[1] >= or_low and not trade_taken_today

// ==================== POSITION MANAGEMENT ====================
// Track breakout candle levels
if buy_signal and strategy.position_size == 0
    breakout_candle_low := low
    breakout_candle_high := high
    entry_price := close
    stop_loss := breakout_candle_low
    sl_points = entry_price - stop_loss
    target := entry_price + (sl_points * 3)

if sell_signal and strategy.position_size == 0
    breakout_candle_high := high
    breakout_candle_low := low
    entry_price := close
    stop_loss := breakout_candle_high
    sl_points = stop_loss - entry_price
    target := entry_price - (sl_points * 3)

// ==================== STRATEGY EXECUTION ====================
// Enter long position
if buy_signal and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    trade_taken_today := true

// Enter short position
if sell_signal and strategy.position_size == 0
    strategy.entry("Short", strategy.short)
    trade_taken_today := true

// Exit long position
if strategy.position_size > 0
    strategy.exit("Exit Long", "Long", stop=stop_loss, limit=target)

// Exit short position
if strategy.position_size < 0
    strategy.exit("Exit Short", "Short", stop=stop_loss, limit=target)

// ==================== VISUALIZATION ====================
// Plot opening range lines
plot(or_formed ? or_high : na, "OR High", color=color.green, linewidth=2, style=plot.style_linebr)
plot(or_formed ? or_low : na, "OR Low", color=color.red, linewidth=2, style=plot.style_linebr)

// Plot entry signals
plotshape(buy_signal, "Buy Signal", shape.triangleup, location.belowbar, color.green, size=size.normal)
plotshape(sell_signal, "Sell Signal", shape.triangledown, location.abovebar, color.red, size=size.normal)

// Plot stop loss and target for active positions
plot(strategy.position_size > 0 ? stop_loss : na, "Long SL", color=color.new(color.red, 0), linewidth=1, style=plot.style_circles)
plot(strategy.position_size > 0 ? target : na, "Long Target", color=color.new(color.green, 0), linewidth=1, style=plot.style_circles)
plot(strategy.position_size < 0 ? stop_loss : na, "Short SL", color=color.new(color.red, 0), linewidth=1, style=plot.style_circles)
plot(strategy.position_size < 0 ? target : na, "Short Target", color=color.new(color.green, 0), linewidth=1, style=plot.style_circles)

// ==================== INFORMATION TABLE ====================
var table info_table = table.new(position.top_right, 2, 5, border_width=1)

if barstate.islast and or_formed
    table.cell(info_table, 0, 0, "OR High", text_color=color.white, bgcolor=color.green)
    table.cell(info_table, 1, 0, str.tostring(or_high, format.mintick), text_color=color.white, bgcolor=color.green)
    
    table.cell(info_table, 0, 1, "OR Low", text_color=color.white, bgcolor=color.red)
    table.cell(info_table, 1, 1, str.tostring(or_low, format.mintick), text_color=color.white, bgcolor=color.red)
    
    table.cell(info_table, 0, 2, "Position", text_color=color.white, bgcolor=color.gray)
    pos_text = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "NONE"
    table.cell(info_table, 1, 2, pos_text, text_color=color.white, bgcolor=color.gray)
    
    if strategy.position_size != 0
        table.cell(info_table, 0, 3, "Stop Loss", text_color=color.white, bgcolor=color.red)
        table.cell(info_table, 1, 3, str.tostring(stop_loss, format.mintick), text_color=color.white, bgcolor=color.red)
        
        table.cell(info_table, 0, 4, "Target", text_color=color.white, bgcolor=color.green)
        table.cell(info_table, 1, 4, str.tostring(target, format.mintick), text_color=color.white, bgcolor=color.green)
